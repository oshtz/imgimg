{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "imgimg",
  "version": "0.1.0",
  "identifier": "com.imgimg.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm --prefix web run dev",
    "beforeBuildCommand": "npm --prefix web run build"
  },
  "app": {
    "windows": [
      {
        "title": "imgimg",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' asset: http://asset.localhost blob: data: https:; media-src 'self' asset: http://asset.localhost blob: data: https:; connect-src 'self' ipc: http://ipc.localhost https: http://localhost:* ws://localhost:* ws://127.0.0.1:*; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/storage/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "signCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/sign-windows.ps1 %1"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../workflows/replicate-*.json": "workflows/",
      "../workflows/fal-*.json": "workflows/",
      "../workflows/openrouter-*.json": "workflows/"
    }
  }
}
