{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "imgimg",
  "version": "0.1.0",
  "identifier": "com.imgimg.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "node scripts/dev.mjs",
    "beforeBuildCommand": "npm --prefix web run build"
  },
  "app": {
    "windows": [
      {
        "title": "imgimg",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/storage/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../workflows/replicate-*.json": "workflows/",
      "../workflows/fal-*.json": "workflows/",
      "../workflows/openrouter-*.json": "workflows/"
    }
  }
}
